      <VolumeEnergyParameters CellType="Hypoxic" LambdaVolume="2.0" TargetVolume="25"/>
      <VolumeEnergyParameters CellType="Endothelial" LambdaVolume="3.0" TargetVolume="25"/>
      <VolumeEnergyParameters CellType="BloodVessel" LambdaVolume="8.0" TargetVolume="25"/>
