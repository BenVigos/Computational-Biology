      <Energy Type1="Medium" Type2="Tumor">16.0</Energy>
      <Energy Type1="Medium" Type2="Hypoxic">16.0</Energy>
      <Energy Type1="Medium" Type2="Endothelial">12.0</Energy>
      <Energy Type1="Medium" Type2="BloodVessel">8.0</Energy>
      <Energy Type1="Tumor" Type2="Tumor">4.0</Energy>
