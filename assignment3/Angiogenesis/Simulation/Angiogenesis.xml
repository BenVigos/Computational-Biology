<CompuCell3D Revision="5" Version="4.7.0">
   <Metadata>
      <NumberOfProcessors>1</NumberOfProcessors>
      <DebugOutputFrequency>50</DebugOutputFrequency>
      <MCSConversionFactor DisplayName="No conversion" Units="-">1.0</MCSConversionFactor>
      <VoxelConversionFactor DisplayName="No conversion" Units="-">1.0</VoxelConversionFactor>
   </Metadata>

   <Potts>
      <Dimensions x="100" y="100" z="1"/>
      <Steps>10000</Steps>
      <Temperature>14.0</Temperature>
      <Flip2DimRatio>1</Flip2DimRatio>
      <NeighborOrder>2</NeighborOrder>
   </Potts>

   <Plugin Name="CellType">
      <CellType TypeId="0" TypeName="Medium"/>
      <CellType TypeId="1" TypeName="Normal"/>
      <CellType TypeId="2" TypeName="Hypoxic"/>
      <CellType TypeId="3" TypeName="Necrotic"/>
      <CellType TypeId="4" TypeName="ActiveNeovascular"/>
      <CellType TypeId="5" TypeName="Vascular" Freeze=""/>
      <CellType TypeId="6" TypeName="InactiveNeovascular"/>
   </Plugin>

   <Plugin Name="CenterOfMass"/>
   <Plugin Name="NeighborTracker"/>
   <Plugin Name="PixelTracker"/>
   <Plugin Name="Volume"/>
   <Plugin Name="Surface"/>

   <Plugin Name="Contact">
      <Energy Type1="Medium" Type2="Medium">0</Energy>
      <Energy Type1="Normal" Type2="Medium">16</Energy>
      <Energy Type1="Normal" Type2="Normal">10</Energy>
      <Energy Type1="Hypoxic" Type2="Medium">16</Energy>
      <Energy Type1="Hypoxic" Type2="Normal">10</Energy>
      <Energy Type1="Hypoxic" Type2="Hypoxic">6</Energy>
      <Energy Type1="Necrotic" Type2="Medium">4</Energy>
      <Energy Type1="Necrotic" Type2="Normal">4</Energy>
      <Energy Type1="Necrotic" Type2="Hypoxic">4</Energy>
      <Energy Type1="Necrotic" Type2="Necrotic">4</Energy>
      <Energy Type1="ActiveNeovascular" Type2="Medium">13</Energy>
      <Energy Type1="ActiveNeovascular" Type2="Normal">18</Energy>
      <Energy Type1="ActiveNeovascular" Type2="Hypoxic">18</Energy>
      <Energy Type1="ActiveNeovascular" Type2="Necrotic">18</Energy>
      <Energy Type1="ActiveNeovascular" Type2="ActiveNeovascular">6</Energy>
      <Energy Type1="Vascular" Type2="Medium">13</Energy>
      <Energy Type1="Vascular" Type2="Normal">25</Energy>
      <Energy Type1="Vascular" Type2="Hypoxic">25</Energy>
      <Energy Type1="Vascular" Type2="Necrotic">25</Energy>
      <Energy Type1="Vascular" Type2="Vascular">6</Energy>
      <Energy Type1="Vascular" Type2="ActiveNeovascular">5</Energy>
      <Energy Type1="InactiveNeovascular" Type2="Medium">13</Energy>
      <Energy Type1="InactiveNeovascular" Type2="Normal">25</Energy>
      <Energy Type1="InactiveNeovascular" Type2="Hypoxic">25</Energy>
      <Energy Type1="InactiveNeovascular" Type2="Necrotic">25</Energy>
      <Energy Type1="InactiveNeovascular" Type2="Vascular">3</Energy>
      <Energy Type1="InactiveNeovascular" Type2="InactiveNeovascular">6</Energy>
      <Energy Type1="InactiveNeovascular" Type2="ActiveNeovascular">3</Energy>
      <NeighborOrder>5</NeighborOrder>
   </Plugin>

   <Plugin Name="Chemotaxis">
      <ChemicalField Name="VEGF1" Source="DiffusionSolverFE">
         <ChemotaxisByType Type="ActiveNeovascular" Lambda="100" ChemotactTo="Medium,Normal,Hypoxic"/>
         <ChemotaxisByType Type="InactiveNeovascular" Lambda="100" ChemotactTo="Medium,Normal,Hypoxic"/>
      </ChemicalField>
      <ChemicalField Name="VEGF2" Source="DiffusionSolverFE">
         <ChemotaxisByType Type="InactiveNeovascular" Lambda="800" SaturationCoef="1"/>
         <ChemotaxisByType Type="ActiveNeovascular" Lambda="800" SaturationCoef="1"/>
      </ChemicalField>
   </Plugin>

   <Steppable Type="DiffusionSolverFE">
      <DiffusionField Name="Oxygen">
         <DiffusionData>
            <FieldName>Oxygen</FieldName>
            <GlobalDiffusionConstant>0.8</GlobalDiffusionConstant><!--was 3440-->
            <GlobalDecayConstant>0.001</GlobalDecayConstant>
            <DeltaT>1</DeltaT>
            <DeltaX>1.0</DeltaX>
            <InitialConcentration Type="Medium">10</InitialConcentration>
         </DiffusionData>
         <SecretionData>
            <Uptake Type="Medium" MaxUptake="0" RelativeUptakeRate="0.2"/>
            <Uptake Type="Hypoxic" MaxUptake="0.5" RelativeUptakeRate="0.2"/>
            <Uptake Type="Normal" MaxUptake="0.3" RelativeUptakeRate="0.2"/>
            <Uptake Type="Necrotic" MaxUptake="0.0001" RelativeUptakeRate="0.2"/>
            <ConstantConcentration Type="Vascular">90</ConstantConcentration>
            <ConstantConcentration Type="ActiveNeovascular">70</ConstantConcentration>
            <ConstantConcentration Type="InactiveNeovascular">70</ConstantConcentration>
         </SecretionData>
      </DiffusionField>

      <DiffusionField Name="VEGF1">
         <DiffusionData>
            <FieldName>VEGF1</FieldName>
            <GlobalDiffusionConstant>0.05</GlobalDiffusionConstant>
            <GlobalDecayConstant>0.05</GlobalDecayConstant>
            <DeltaT>1</DeltaT>
            <DeltaX>1.0</DeltaX>
         </DiffusionData>
         <SecretionData>
            <Secretion Type="ActiveNeovascular">0.2</Secretion>
            <Secretion Type="InactiveNeovascular">0.2</Secretion>
            <Secretion Type="Vascular">0.2</Secretion>
         </SecretionData>
      </DiffusionField>

      <DiffusionField Name="VEGF2">
         <DiffusionData>
            <FieldName>VEGF2</FieldName>
            <GlobalDiffusionConstant>1.5</GlobalDiffusionConstant>
            <GlobalDecayConstant>0.02</GlobalDecayConstant>
            <DeltaT>1</DeltaT>
            <DeltaX>1.0</DeltaX>
         </DiffusionData>
         <SecretionData>
            <Secretion Type="Hypoxic">10</Secretion>
         </SecretionData>
      </DiffusionField>
   </Steppable>
</CompuCell3D>
