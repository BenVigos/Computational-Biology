<CompuCell3D Revision="20210612" Version="4.2.5">
   <Potts>
      <Dimensions x="200" y="200" z="1"/>
      <Steps>10000</Steps>
      <Temperature>10.0</Temperature>
      <NeighborOrder>1</NeighborOrder>
   </Potts>

   <Plugin Name="CellType">
      <CellType TypeId="0" TypeName="Medium"/>
      <CellType TypeId="1" TypeName="Tumor"/>
      <CellType TypeId="2" TypeName="Hypoxic"/>
      <CellType TypeId="3" TypeName="Endothelial"/>
      <CellType TypeId="4" TypeName="ECM" Freeze=""/> 
   </Plugin>

   <Plugin Name="Volume">
      <VolumeEnergyParameters CellType="Tumor" LambdaVolume="2.0" TargetVolume="25"/>
      <VolumeEnergyParameters CellType="Hypoxic" LambdaVolume="2.0" TargetVolume="25"/>
      <VolumeEnergyParameters CellType="Endothelial" LambdaVolume="2.0" TargetVolume="25"/>
      <VolumeEnergyParameters CellType="ECM" LambdaVolume="4.0" TargetVolume="25"/>
   </Plugin>

   <Plugin Name="Contact">
      <Energy Type1="Medium" Type2="Medium">10.0</Energy>
      <Energy Type1="Tumor" Type2="Tumor">4.0</Energy>
      <Energy Type1="Endothelial" Type2="Endothelial">4.0</Energy>
      <Energy Type1="Endothelial" Type2="Tumor">15.0</Energy>
      <Energy Type1="Medium" Type2="Tumor">10.0</Energy>
      <Energy Type1="ECM" Type2="Endothelial">10.0</Energy>
      <NeighborOrder>1</NeighborOrder>
   </Plugin>

   <Plugin Name="Chemotaxis">
      <ChemicalField Name="VEGF" Source="DiffusionSolverFE">
         <ChemotaxisByType ChemotactTo="Medium" Lambda="500.0" Type="Endothelial"/>
      </ChemicalField>
   </Plugin>

   <Steppable Type="DiffusionSolverFE">
      <DiffusionField Name="Oxygen">
         <DiffusionData>
            <FieldName>Oxygen</FieldName>
            <GlobalDiffusionConstant>0.2</GlobalDiffusionConstant>
            <GlobalDecayConstant>1e-05</GlobalDecayConstant>
         </DiffusionData>
         <SecretionData>
            <Secretion Type="Endothelial">0.5</Secretion>
            <Secretion Type="Medium">0.05</Secretion>
         </SecretionData>
      </DiffusionField>
      <DiffusionField Name="VEGF">
         <DiffusionData>
            <FieldName>VEGF</FieldName>
            <GlobalDiffusionConstant>0.1</GlobalDiffusionConstant>
            <GlobalDecayConstant>0.01</GlobalDecayConstant>
         </DiffusionData>
      </DiffusionField>
      <DiffusionField Name="MMP">
         <DiffusionData>
            <FieldName>MMP</FieldName>
            <GlobalDiffusionConstant>0.05</GlobalDiffusionConstant>
            <GlobalDecayConstant>0.1</GlobalDecayConstant>
         </DiffusionData>
      </DiffusionField>
   </Steppable>
</CompuCell3D>